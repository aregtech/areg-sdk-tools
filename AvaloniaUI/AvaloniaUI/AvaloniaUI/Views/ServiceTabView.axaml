<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:AvaloniaUI.Views.Converters"
             xmlns:viewModels="clr-namespace:AvaloniaUI.ViewModels"
             xmlns:dataTemplates="clr-namespace:AvaloniaUI.Views.DataTemplates"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             xmlns:views="clr-namespace:AvaloniaUI.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaUI.Views.ServiceTabView"
             x:Name="ServiceTabViewUserControl">

    <!-- The problem with the TabControl, it shares its content template for all tabs. See:
    https://github.com/AvaloniaUI/Avalonia/issues/14529
    https://github.com/AvaloniaUI/Avalonia/discussions/11837 -->
    <UserControl.IsVisible>
        <MultiBinding Converter="{x:Static converters:IsEqualConverter.Instance}">
            <Binding />
            <Binding RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=ItemsControl}"
                     Path="DataContext.SelectedServiceTabItem.Content">
            </Binding>
        </MultiBinding>
    </UserControl.IsVisible>

    <UserControl.Resources>
        <DataTemplate x:Key="BasicAspectInfo">
            <TextBlock Text="{Binding ServiceAspectType, StringFormat='{}{0} Editor'}"
                       FontStyle="Italic"
                       FontSize="20" 
                       Margin="5 10 5 10"/>
        </DataTemplate>
    </UserControl.Resources>

    <!-- The DataContext here is a "ServiceAspectTabItem" instance -->
    <UserControl.DataTemplates>
        <dataTemplates:ServiceAspectsTemplateSelector>
            <DataTemplate x:Key="Overview" DataType="viewModels:ServiceAspectType">
                <StackPanel Orientation="Vertical"
                            DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ContentControl},
                            Path=DataContext}">
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{DynamicResource BasicAspectInfo}"/>
                    <views:OverViewAspectView />
                </StackPanel>
            </DataTemplate>
            <DataTemplate x:Key="DataTypes" DataType="viewModels:ServiceAspectType">
                <ListBox>
                    <ListBoxItem>DataTypes</ListBoxItem>
                    <ListBoxItem>DataTypes</ListBoxItem>
                </ListBox>
            </DataTemplate>
            <DataTemplate x:Key="Attributes" DataType="viewModels:ServiceAspectType">
                <ListBox>
                    <ListBoxItem>Attributes</ListBoxItem>
                    <ListBoxItem>Attributes</ListBoxItem>
                </ListBox>
            </DataTemplate>
            <DataTemplate x:Key="Methods" DataType="viewModels:ServiceAspectType">
                <ListBox>
                    <ListBoxItem>Methods</ListBoxItem>
                    <ListBoxItem>Methods</ListBoxItem>
                </ListBox>
            </DataTemplate>
            <DataTemplate x:Key="Constants" DataType="viewModels:ServiceAspectType">
                <ListBox>
                    <ListBoxItem>Constants</ListBoxItem>
                    <ListBoxItem>Constants</ListBoxItem>
                </ListBox>
            </DataTemplate>
            <DataTemplate x:Key="Includes" DataType="viewModels:ServiceAspectType">
                <ListBox>
                    <ListBoxItem>Includes</ListBoxItem>
                    <ListBoxItem>Includes</ListBoxItem>
                </ListBox>
            </DataTemplate>
        </dataTemplates:ServiceAspectsTemplateSelector>
    </UserControl.DataTemplates>

    <Border BorderThickness="1"
            BorderBrush="WhiteSmoke">
        <DockPanel>
            <TabStrip DockPanel.Dock="Bottom"
                      Name="ServiceAspectTabStrip"
                      ItemsSource="{Binding ServiceAspectTabItems}"
                      SelectedItem="{Binding SelectedServiceAspectTabItem}">
                <TabStrip.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Header}"
                                   FontSize="{DynamicResource TabItemFontSize}" />
                    </DataTemplate>
                </TabStrip.ItemTemplate>

                <TabStrip.Resources>
                    <system:Int32 x:Key="TabItemFontSize">12</system:Int32>
                </TabStrip.Resources>
            </TabStrip>

            <ItemsControl DockPanel.Dock="Top"
                          ItemsSource="{Binding ServiceAspectTabItems}"
                          Name="ServiceAcpectTabsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Panel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:ServiceAspectTabItem}">
                        <ContentControl Content="{Binding ServiceAspectType, Mode=OneWay}"
                                        Name="ServiceAcpectContentControl">
                            <ContentControl.IsVisible>
                                <MultiBinding Converter="{x:Static converters:IsEqualConverter.Instance}">
                                    <Binding />
                                    <Binding
                                        RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=ItemsControl}"
                                        Path="DataContext.SelectedServiceAspectTabItem">
                                    </Binding>
                                </MultiBinding>
                            </ContentControl.IsVisible>
                        </ContentControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
    </Border>
</UserControl>