<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:AvaloniaUI.ViewModels"
             xmlns:views="clr-namespace:AvaloniaUI.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaUI.Views.WorkspaceView">
    
    <UserControl.DataContext>
        <viewModels:WorkspaceViewModel/>
    </UserControl.DataContext>

    <Grid ColumnDefinitions="*, 8, 5*">
        <views:ExplorerView Grid.Column="0"/>

        <GridSplitter Grid.Column="1" Background="Black" ResizeDirection="Columns"/>
        
        <views:ServiceTabView Grid.Column="2"/>
    </Grid>
</UserControl>
