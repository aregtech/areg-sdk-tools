<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:AvaloniaUI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="viewModels:OpenServiceViewModel"
             x:Class="AvaloniaUI.Views.OpenServiceView">
    <Grid
        RowDefinitions="Auto, Auto"
        ColumnDefinitions="Auto, Auto">
        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Selected Service File:" />

        <ListBox
            Grid.Row="0"
            Grid.Column="1"
            ItemsSource="{Binding SelectedServiceFiles}" />
    </Grid>
</UserControl>