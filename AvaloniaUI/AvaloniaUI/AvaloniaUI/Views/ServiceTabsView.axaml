<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:viewModels="clr-namespace:AvaloniaUI.ViewModels"
             xmlns:views="clr-namespace:AvaloniaUI.Views"
             x:Class="AvaloniaUI.Views.ServiceTabsView"
             Background="SteelBlue">

    <UserControl.DataContext>
        <viewModels:ServiceTabsViewModel />
    </UserControl.DataContext>

    <Grid>
        <TabControl ItemsSource="{Binding ServiceTabItems}"
                    SelectedItem="{Binding SelectedServiceTabItem}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Header}"
                               FontSize="14" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type viewModels:ServiceTabItem}">
                    <views:SingleServiceView DataContext="{Binding Content}" />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

    </Grid>
</UserControl>